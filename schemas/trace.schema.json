{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/pra/trace.schema.json",
  "title": "PRA Trace",
  "type": "object",
  "required": ["id", "alias", "edge_sets", "nodes"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "alias": { "type": "string" },
    "context": { "type": "string" },
    "edge_sets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "layout": {
      "type": "object"
    }
  }
}
